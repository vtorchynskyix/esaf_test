{
  "version": "0.2.0",
  "configurations": [
    
    {
      "name": "STM32G0 Debug (OpenOCD)",
      "type": "cppdbg",
      "request": "launch",

      "program": "${workspaceFolder}/build/sting.elf",
      "cwd": "${workspaceFolder}",

      "MIMode": "gdb",
      "miDebuggerPath": "arm-none-eabi-gdb",

      "setupCommands": [
        {
          "description": "Enable pretty-printing",
          "text": "-enable-pretty-printing",
          "ignoreFailures": true
        }
      ],

      "miDebuggerServerAddress": "localhost:3333",

      "debugServerPath": "openocd",
      "debugServerArgs": "-f interface/stlink.cfg -f target/stm32g0x.cfg",

      "serverStarted": "Listening on port 3333",
      "filterStdout": true,
      "filterStderr": true,

      "preLaunchTask": "build",

      "postRemoteConnectCommands": [
        {
          "text": "monitor reset halt"
        },
        {
          "text": "load"
        },
        {
          "text": "monitor reset init"
        }
      ],

      "externalConsole": false,
      "stopAtEntry": true
    }
  ]
}